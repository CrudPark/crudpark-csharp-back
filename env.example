# Database Configuration
ConnectionStrings__DefaultConnection=Server=localhost;Database=CrudParkDB;Trusted_Connection=true;MultipleActiveResultSets=true

# Email Configuration
EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SmtpUsername=your-email@gmail.com
EmailSettings__SmtpPassword=your-app-password
EmailSettings__FromEmail=your-email@gmail.com
EmailSettings__FromName=Sistema Parqueadero

# Parking Settings
ParkingSettings__GraceTimeMinutes=30
ParkingSettings__DefaultHourlyRate=2000
ParkingSettings__DefaultFractionRate=500
ParkingSettings__DefaultDailyCap=20000

# Docker Environment Variables
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
